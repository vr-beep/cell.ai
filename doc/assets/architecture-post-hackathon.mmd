%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#f9f9f9', 'primaryBorderColor': '#333', 'lineColor': '#333'}}}%%

graph TB
    subgraph CORE["CORE LOOP (from hackathon)"]
        direction LR
        Input["Input:\nCell type +\ncomponents"]
        Optimizer["Elnora MCP +\nBayBE optimizer"]
        Robot["Monomer MCP\n(robot execution)"]
        Results["OD600 → growth rate\n+ dashboard"]
        Input --> Optimizer --> Robot --> Results
        Results -->|"Closed-loop\nfeedback"| Optimizer
    end

    subgraph POSTHACK["POST-HACKATHON ADDITIONS"]
        direction TB

        subgraph SURROGATE["Digital Twin / Surrogate Model"]
            SurrogateModel["Learned surrogate model\n(trained on 100+ campaigns)"]
            PreScreen["Pre-screen candidate\ncompositions in silico\nbefore wet lab"]
            SurrogateModel --> PreScreen
        end

        subgraph RL["Reinforcement Learning (long-term)"]
            RLAgent["RL agent trained on\nhistorical campaign data"]
            RLPolicy["Learns optimization\npolicies across cell types\n& media formulations"]
            RLAgent --> RLPolicy
        end

        subgraph EXPANDED["Expanded Scope"]
            MultiCell["Multiple cell types\n(beyond V. natriegens)"]
            Contam["Contamination detection\n+ remediation\n(requires days of data)"]
            Passage["Passaging / cell\nexpansion workflows"]
            Potency["Functional characterization\n(potency, phenotype)"]
            MultiComp["Optimize N components\n(beyond 3)"]
        end

        subgraph MULTICAMPAIGN["Multi-Campaign Learning"]
            DataStore["Centralized experiment\ndatabase across campaigns"]
            Transfer["Transfer learning:\npriors from past campaigns\ninform new cell types"]
            DataStore --> Transfer
        end

        subgraph PRODUCT["Product Features"]
            Auth["Multi-user / team auth"]
            LabInventory["Lab inventory integration\n(constrain by what's on-hand)"]
            Export["Export recipes to\nlab protocols (SOP)"]
            CostOpt["Cost-aware optimization\n(growth vs. reagent cost)"]
        end
    end

    Results -->|"Accumulated data\n(100+ campaigns)"| SurrogateModel
    PreScreen -->|"Top candidates\nonly"| Optimizer
    Transfer -->|"Informed priors"| Optimizer
    RLPolicy -.->|"Future:\nreplaces BayBE"| Optimizer

    style CORE fill:#f3fff3,stroke:#00aa00,stroke-width:2px
    style POSTHACK fill:#f0f0ff,stroke:#6666cc,stroke-width:2px
    style SURROGATE fill:#fff3e6,stroke:#cc6600,stroke-width:1px
    style RL fill:#ffe6e6,stroke:#cc0000,stroke-width:1px,stroke-dasharray: 5 5
    style EXPANDED fill:#e6f3ff,stroke:#0066cc,stroke-width:1px
    style MULTICAMPAIGN fill:#e6ffe6,stroke:#00aa00,stroke-width:1px
    style PRODUCT fill:#f9f9f9,stroke:#999,stroke-width:1px
